# Local Postgres example (adjust user/password/db name to match your setup):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tournament?schema=public"

# Admin authentication
ADMIN_PASSWORD="pick-a-real-password"
SESSION_SECRET="a-long-random-string"

# Neon Postgres (production) — get these from your Neon project's Connection Details
# DATABASE_URL is the pooled connection (for the app), DIRECT_URL is the direct
# connection (for migrations). Both point to the same database.
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
